                    },
                    "animations": [
                        {
                            "id": "circle-scale-x",
                            "property": "scale.x",
                            "easing": "easeInOutSine",
                            "duration": 3000,
                            "loops": -1,
                            "keyframes": [
                                {
                                    "time": 0,
                                    "value": 1
                                },
                                {
                                    "time": 1500,
                                    "value": 1.4
                                },
                                {
                                    "time": 3000,
                                    "value": 1
                                }
                            ]
                        },
                        {
                            "id": "circle-scale-y",
                            "property": "scale.y",
                            "easing": "easeInOutSine",
                            "duration": 3000,
                            "loops": -1,
                            "keyframes": [
                                {
                                    "time": 0,
                                    "value": 1
                                },
                                {
                                    "time": 1500,
                                    "value": 1.4
                                },
                                {
                                    "time": 3000,
                                    "value": 1
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "sliding-diamond",
                    "type": "shape",
                    "position": {
                        "x": 650,
                        "y": 280
                    },
                    "rotation": 45,
                    "styles": {
                        "shape": "rect",
                        "width": 60,
                        "height": 60,
                        "fill": "#a78bfa",
                        "stroke": "#8b5cf6",
                        "strokeWidth": 2
                    },
                    "animations": [
                        {
                            "id": "diamond-slide-x",
                            "property": "position.x",
                            "easing": "easeInOutQuad",
                            "duration": 3000,
                            "loops": -1,
                            "keyframes": [
                                {
                                    "time": 0,
                                    "value": 550
                                },
                                {
                                    "time": 1500,
                                    "value": 700
                                },
                                {
                                    "time": 3000,
                                    "value": 550
                                }
                            ]
                        },
                        {
                            "id": "diamond-fade",
                            "property": "opacity",
                            "easing": "easeInOutSine",
                            "duration": 3000,
                            "loops": -1,
                            "keyframes": [
                                {
                                    "time": 0,
                                    "value": 0.5
                                },
                                {
                                    "time": 1500,
                                    "value": 1
                                },
                                {
                                    "time": 3000,
                                    "value": 0.5
                                }
                            ]
                        }
                    ]
                },
                {
                    "id": "subtitle-text",
                    "type": "text",
                    "position": {
                        "x": 400,
                        "y": 440
                    },
                    "opacity": 0,
                    "styles": {
                        "content": "DSL → Parse → Validate → Animate → Render",
                        "fontSize": 16,
                        "fontFamily": "monospace",
                        "fill": "#a1a1aa"
                    },
                    "animations": [
                        {
                            "id": "subtitle-fade-in",
                            "property": "opacity",
                            "easing": "easeOutCubic",
                            "duration": 2000,
                            "delay": 1000,
                            "keyframes": [
                                {
                                    "time": 0,
                                    "value": 0
                                },
                                {
                                    "time": 2000,
                                    "value": 0.8
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}